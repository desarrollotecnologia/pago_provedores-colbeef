# =============================================================================
# PAGO PROVEEDORES - COLBEEF
# Copiar este archivo a .env y ajustar SOLO los valores marcados con <<< 
# El frontend usa rutas relativas (/api) — no requiere cambios al migrar.
# =============================================================================

# <<< Cambiar en cada servidor
DATABASE_URL=mysql+pymysql://root:@localhost:3306/pago_proveedores?charset=utf8mb4
SECRET_KEY=generar-clave-segura-minimo-32-caracteres-aqui

# URL pública del servidor — usar la IP o dominio que comparten (no localhost en red)
APP_URL=http://192.168.20.205:8100
APP_NAME=Pago Proveedores - Colbeef
APP_ENV=production

# Red
API_HOST=0.0.0.0
API_PORT=8100

# CORS (opcional; agregar IP si acceden desde otro puerto u origen)
# CORS_ORIGINS=http://192.168.20.205:8100

# Rutas relativas al proyecto — normalmente NO cambiar
OUTPUT_DIR=output
STATIC_DIR=frontend/dist

# Sesión
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Archivo plano bancario
CIUDAD_DEFAULT=BOGOTA

# Correos SMTP <<< configurar en producción
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=coordinacion.tesoreria@colbeef.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=coordinacion.tesoreria@colbeef.com
SMTP_FROM_NAME=Coordinación Tesorería
SMTP_USE_TLS=true

# Importación inicial Excel (solo primera vez)
EXCEL_PATH=

# MySQL Windows (solo scripts .bat locales)
MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.4\bin
MYSQL_DATA=C:\ProgramData\MySQL\MySQL Server 8.4\Data

# Firma de correo (HTML + banner Colbeef)
EMAIL_FIRMA_NOMBRE=Viviana Andrea Pineda Triana
EMAIL_FIRMA_CARGO=Coordinadora de Tesorería y Cartera
EMAIL_FIRMA_EMPRESA=Colbeef SAS
EMAIL_FIRMA_TELEFONO=+57 3182111459
EMAIL_FIRMA_EMAIL=coordinacion.tesoreria@colbeef.com
EMAIL_FIRMA_DIRECCION=Vía Corredor Río Frío Cll 210 N 9-631, Floridablanca, Santander
EMAIL_FIRMA_WEB=www.colbeef.com
# EMAIL_FIRMA_BANNER_PATH=ruta\opcional\banner.png
# EMAIL_FIRMA_BANNER_URL=https://servidor/email-banner-colbeef.png
